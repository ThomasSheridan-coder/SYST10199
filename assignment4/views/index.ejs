<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Loan Interest Calculator</title>
    <link rel="stylesheet" href="/style.css" />
</head>
<!--This part is for getting the HTML with the language option, encoading 
the UTF-8 system, and putting the head in so the meta, title, and
the link to the css can be inside of the head format.-->

<body>
    <div class="container">
        <!--This div class is the main wrapper-->
        <h1>Loan Interest Calculator</h1>

        <div class="card">
            <!--This div class will style the card container for the instructions-->
            <p><strong>Enter in the data by using the URL like this:</strong></p>
            <p>/calculate?amount=10000&rate=6.5</p>
            <p><strong>Example of full URL:</strong></p>
            <p>http://localhost:3000/calculate?amount=10000&rate=6.5</p>
        </div>
    </div>
</body>
</html>